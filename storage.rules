rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnder(sizeMb) {
      return request.resource.size < sizeMb * 1024 * 1024;
    }

    function isSchoolMember(schoolId) {
      // Cross-service lookup: requires the user's /users/{uid} doc to list
      // schoolId in its `schools` map (or isSuperAdmin=true).
      let userDoc = firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
      return isSignedIn() && (
        userDoc.data.get('isSuperAdmin', false) == true ||
        ('schools' in userDoc.data && schoolId in userDoc.data.schools)
      );
    }

    // --- Avatars (publiquement lisibles, upload par le propriétaire) ---

    match /ecoles/{schoolId}/parents/{parentId}/avatars/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() &&
                   request.auth.uid == parentId &&
                   isImage() && isUnder(5);
      allow delete: if isSignedIn() && request.auth.uid == parentId;
    }

    match /ecoles/{schoolId}/staff/{staffId}/avatars/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() &&
                   request.auth.uid == staffId &&
                   isImage() && isUnder(5);
      allow delete: if isSignedIn() && request.auth.uid == staffId;
    }

    match /ecoles/{schoolId}/eleves/{studentId}/avatars/{allPaths=**} {
      allow read: if true;
      // Only staff members of the same school can upload a student's avatar.
      allow write: if isSchoolMember(schoolId) && isImage() && isUnder(5);
      allow delete: if isSchoolMember(schoolId);
    }

    // --- Logos d'école (publiquement lisibles, upload par membre de l'école) ---

    match /ecoles/{schoolId}/logos/{allPaths=**} {
      allow read: if true;
      allow write: if isSchoolMember(schoolId) && isImage() && isUnder(2);
      allow delete: if isSchoolMember(schoolId);
    }

    // --- Logos temporaires (pendant l'onboarding, avant création de l'école) ---

    match /temp-logos/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() &&
                   request.auth.uid == userId &&
                   isImage() && isUnder(2);
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Documents d'école (bulletins, reçus, pièces jointes) ---

    match /ecoles/{schoolId}/documents/{allPaths=**} {
      allow read: if isSchoolMember(schoolId);
      allow write: if isSchoolMember(schoolId) && isUnder(20);
      allow delete: if isSchoolMember(schoolId);
    }

    // --- Preuves de paiement (reçus scannés, chèques) ---
    // Données financières sensibles : lecture réservée aux membres de l'école.

    match /ecoles/{schoolId}/eleves/{studentId}/paiements/{allPaths=**} {
      allow read: if isSchoolMember(schoolId);
      allow write: if isSchoolMember(schoolId) && isUnder(10);
      allow delete: if isSchoolMember(schoolId);
    }

    // --- Photos d'inventaire, couvertures de bibliothèque, signatures ---

    match /ecoles/{schoolId}/inventory-photos/{allPaths=**} {
      allow read: if isSchoolMember(schoolId);
      allow write: if isSchoolMember(schoolId) && isImage() && isUnder(5);
      allow delete: if isSchoolMember(schoolId);
    }

    match /ecoles/{schoolId}/library_covers/{allPaths=**} {
      allow read: if true;
      allow write: if isSchoolMember(schoolId) && isImage() && isUnder(5);
      allow delete: if isSchoolMember(schoolId);
    }

    match /ecoles/{schoolId}/signatures/{allPaths=**} {
      allow read: if isSchoolMember(schoolId);
      allow write: if isSchoolMember(schoolId) && isImage() && isUnder(2);
      allow delete: if isSchoolMember(schoolId);
    }

    // --- Photos staff/élèves (paths historiques hors /avatars/) ---

    match /ecoles/{schoolId}/staff-photos/{allPaths=**} {
      allow read: if true;
      allow write: if isSchoolMember(schoolId) && isImage() && isUnder(5);
      allow delete: if isSchoolMember(schoolId);
    }

    match /ecoles/{schoolId}/student-photos/{allPaths=**} {
      allow read: if true;
      allow write: if isSchoolMember(schoolId) && isImage() && isUnder(5);
      allow delete: if isSchoolMember(schoolId);
    }

    // --- Images génériques (décorations, etc. — hérité de l'ancienne app) ---

    match /Images/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isImage() && isUnder(5);
    }

    // Tout le reste est interdit. Ne PAS ajouter de règle catch-all permissive :
    // elle annulerait toutes les restrictions ci-dessus.
  }
}
