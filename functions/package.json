{
  "name": "gereecole-functions",
  "version": "1.0.0",
  "description": "Cloud Functions for GèreEcole (scheduled jobs).",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "seed:subs": "ts-node scripts/seed-test-subscriptions.ts",
    "seed:subs:clean": "ts-node scripts/seed-test-subscriptions.ts --cleanup",
    "backfill:year": "ts-node scripts/backfill-academic-year.ts",
    "backfill:year:dry": "ts-node scripts/backfill-academic-year.ts --dry-run"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.0.1"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "ts-node": "^10.9.2"
  },
  "private": true
}
